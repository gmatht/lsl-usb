# LSL-USB data directory (edit on the USB FAT partition; no squashfs rebuild needed).
# Default: Windows user folder on NTFS (HDD mode — direct btrfs, no idle squashfs batching).
LSL_DATA_DIR=/mnt/c/Users/lsl-usb

# USB mode is detected automatically: path resolves under /cdrom or /persist.
# HDD mode: any other path (typical: /mnt/c/...).

# Idle seconds before flushing /home overlay to home.sfs on USB (linear mksquashfs write).
LSL_HOME_IDLE_SEC=300

# Initial sparse image sizes (Mebibytes) when creating home.btrfs / cache.btrfs on HDD.
# cache.btrfs holds /var/cache, ~/.cache, and most of Nix (/nix/store, /nix/var); increase if you use Nix heavily.
LSL_HOME_BTRFS_MIB=4096
LSL_CACHE_BTRFS_MIB=2048

# tmpfs size for USB-mode /home overlay upper+work (Mebibytes).
LSL_HOME_TMPFS_MIB=2048

# zram swap size (Mebibytes). Empty = 80% of RAM (min 128). Set to 0 to disable.
# LSL_ZRAM_MIB=

# Grow home.btrfs on HDD when free space falls below this percent (or chunk grow size).
LSL_BTRFS_MIN_FREE_PCT=10
LSL_BTRFS_GROW_CHUNK_MIB=1024
