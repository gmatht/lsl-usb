#!/bin/bash
# lsl-gui - GUI launcher for Linux Services for Linux - WSL emulator
# Provides a graphical interface to select and run WSL distributions

WSL_REPORT="${WSL_REPORT:-/tmp/wsl}"
LSL_SCRIPT_DIR="$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")"
LSL_SCRIPT="$LSL_SCRIPT_DIR/lsl"

run_privileged() {
    # Run a command with privileges if possible.
    # Prefer pkexec for GUI prompts; fall back to sudo.
    if [ "${EUID:-$(id -u)}" -eq 0 ]; then
        "$@"
        return $?
    fi

    if command -v pkexec >/dev/null 2>&1; then
        pkexec "$@"
        return $?
    fi

    if command -v sudo >/dev/null 2>&1; then
        sudo "$@"
        return $?
    fi

    return 1
}

# Function to ensure WSL report exists by running detect-wsl if needed
ensure_wsl_report() {
    if [ ! -f "$WSL_REPORT" ] || [ ! -s "$WSL_REPORT" ] || grep -q "No WSL distributions found" "$WSL_REPORT" 2>/dev/null; then
        # Prefer mounting Windows volumes (C:, D:) and then detecting.
        if command -v wsl-boot-setup >/dev/null 2>&1; then
            run_privileged wsl-boot-setup >/dev/null 2>&1 || true
        elif [ -x "/cdrom/bin/wsl-boot-setup" ]; then
            run_privileged /cdrom/bin/wsl-boot-setup >/dev/null 2>&1 || true
        fi

        # Fallback: just run detect-wsl if available
        if command -v detect-wsl >/dev/null 2>&1; then
            run_privileged detect-wsl >/dev/null 2>&1 || true
        elif [ -x "/cdrom/bin/detect-wsl" ]; then
            run_privileged /cdrom/bin/detect-wsl >/dev/null 2>&1 || true
        fi
    fi
}

# Function to parse WSL report and extract VHDX/distro mappings
parse_wsl_report() {
    local vhdx_file=""
    local rootfs_path=""
    local distro_name=""
    local registry_name=""
    
    # Ensure report exists (will try to run detect-wsl if needed)
    ensure_wsl_report
    
    if [ ! -f "$WSL_REPORT" ] || [ ! -s "$WSL_REPORT" ]; then
        return 1
    fi
    
    flush_entry() {
        local name=""

        if [ -n "$registry_name" ]; then
            name="$registry_name"
        fi

        if [ -n "$rootfs_path" ]; then
            if [[ "$rootfs_path" =~ Packages/([^/]+)/LocalState/rootfs$ ]]; then
                name="${BASH_REMATCH[1]}"
            elif [[ "$rootfs_path" =~ /([^/]+)/rootfs$ ]]; then
                name="${BASH_REMATCH[1]}"
            elif [[ "$rootfs_path" =~ distros/([^/]+) ]]; then
                name="${BASH_REMATCH[1]}"
            else
                name="$(basename "$(dirname "$rootfs_path")")"
            fi
        elif [ -n "$vhdx_file" ]; then
            if [[ "$vhdx_file" =~ Packages/([^/]+)/LocalState/ ]]; then
                name="${BASH_REMATCH[1]}"
            else
                name="$(basename "$vhdx_file")"
            fi
        fi

        if [ -z "$name" ]; then
            return 0
        fi

        if [ -n "$vhdx_file" ] && [ -f "$vhdx_file" ]; then
            echo "$name|$vhdx_file|$rootfs_path"
            return 0
        fi

        if [ -n "$rootfs_path" ] && [ -d "$rootfs_path" ]; then
            echo "$name||$rootfs_path"
            return 0
        fi
        return 0
    }

    while IFS= read -r line; do
        if [[ "$line" =~ ^Found\ ext4\.vhdx:\ (.+)$ ]]; then
            vhdx_file="${BASH_REMATCH[1]}"
        elif [[ "$line" =~ ^Found\ vhdx:\ (.+)$ ]]; then
            vhdx_file="${BASH_REMATCH[1]}"
        elif [[ "$line" =~ ^WSL\ (Distro|Custom|LXSS)\ vhdx:\ (.+)$ ]]; then
            vhdx_file="${BASH_REMATCH[2]}"
        elif [[ "$line" =~ ^WSL\ Registry\ vhdx:\ (.+)$ ]]; then
            vhdx_file="${BASH_REMATCH[1]}"
        elif [[ "$line" =~ ^WSL\ Registry\ name:\ (.+)$ ]]; then
            registry_name="${BASH_REMATCH[1]}"
        elif [[ "$line" =~ ^WSL\ (Distro|Custom|LXSS)\ rootfs:\ (.+)$ ]]; then
            rootfs_path="${BASH_REMATCH[2]}"
        elif [[ "$line" == "---" ]]; then
            flush_entry
            vhdx_file=""
            rootfs_path=""
            distro_name=""
            registry_name=""
        fi
    done < "$WSL_REPORT"

    flush_entry
}

# Check for GUI tools
GUI_TOOL=""
if command -v zenity >/dev/null 2>&1; then
    GUI_TOOL="zenity"
elif command -v dialog >/dev/null 2>&1; then
    GUI_TOOL="dialog"
elif command -v whiptail >/dev/null 2>&1; then
    GUI_TOOL="whiptail"
fi

# Function to show error dialog
show_error() {
    local message="$1"
    if [ "$GUI_TOOL" = "zenity" ]; then
        zenity --error --text="$message" --title="lsl-gui Error" 2>/dev/null
    else
        echo "Error: $message" >&2
    fi
}

browse_vhdx() {
    local picked=""

    if [ "$GUI_TOOL" = "zenity" ]; then
        picked=$(zenity --file-selection \
            --title="Select VHDX file" \
            --file-filter="VHDX files (*.vhdx) | *.vhdx" \
            --file-filter="All files | *" 2>/dev/null) || true
    elif [ "$GUI_TOOL" = "dialog" ]; then
        picked=$(dialog --fselect "/" 20 80 2>&1 >/dev/tty) || true
    elif [ "$GUI_TOOL" = "whiptail" ]; then
        picked=$(whiptail --inputbox "Enter path to VHDX file (.vhdx):" 10 80 "" 3>&1 1>&2 2>&3) || true
    else
        read -r -p "Enter path to VHDX file (.vhdx): " picked
    fi

    picked="${picked//$'\r'/}"

    if [ -z "$picked" ]; then
        return 1
    fi

    if [ ! -f "$picked" ]; then
        show_error "VHDX file not found:\n$picked"
        return 1
    fi

    echo "$picked"
    return 0
}

# Main GUI selection
main() {
    # Ensure WSL report exists (will try to run detect-wsl if needed)
    ensure_wsl_report
    
    # Check if WSL report exists
    if [ ! -f "$WSL_REPORT" ] || [ ! -s "$WSL_REPORT" ]; then
        show_error "WSL report not found at $WSL_REPORT

Could not detect WSL distributions. Please ensure Windows partitions are mounted."
        exit 1
    fi
    
    # Build arrays for selection
    local distro_names=()
    local distro_paths=()
    local menu_items=()
    
    populate_distros() {
        distro_names=()
        distro_paths=()
        menu_items=()

        while IFS='|' read -r name vhdx rootfs; do
            if [ -n "$name" ]; then
                local status=""
                if [ -n "$vhdx" ] && [ -f "$vhdx" ]; then
                    status="(VHDX)"
                elif [ -n "$rootfs" ] && [ -d "$rootfs" ]; then
                    status="(rootfs)"
                else
                    status="(unavailable)"
                fi
                distro_names+=("$name")
                distro_paths+=("$vhdx|$rootfs")
                menu_items+=("${#distro_names[@]}" "$name $status")
            fi
        done < <(parse_wsl_report 2>/dev/null)
    }

    populate_distros
    
    if [ ${#distro_names[@]} -eq 0 ]; then
        # Try one more time: re-run detect-wsl and repopulate.
        ensure_wsl_report
        populate_distros

        if [ ${#distro_names[@]} -eq 0 ]; then
            show_error "No WSL distributions found.

Tried mounting Windows partitions automatically and rerunning detection.

If this still fails, set LSL_WIN_C_DEV (and optionally LSL_WIN_D_DEV) and run: sudo wsl-boot-setup"
            exit 1
        fi
    fi
    
    # Show selection dialog
    local selected=""
    local selected_name=""
    local selected_vhdx=""
    
    if [ "$GUI_TOOL" = "zenity" ]; then
        # Build list for zenity
        local list_items=""
        for i in "${!distro_names[@]}"; do
            local num=$((i + 1))
            local item="${distro_names[$i]}"
            local path_info="${distro_paths[$i]}"
            IFS='|' read -r vhdx rootfs <<< "$path_info"
            local status=""
            local location=""
            if [ -n "$vhdx" ] && [ -f "$vhdx" ]; then
                status="VHDX"
                location="$vhdx"
            elif [ -n "$rootfs" ] && [ -d "$rootfs" ]; then
                status="rootfs"
                location="$rootfs"
            else
                status="unavailable"
                location=""
            fi
            list_items+="$num|$item|$status|$location\n"
        done
        
        selected=$(echo -e "$list_items" | zenity --list \
            --title="Select WSL Distribution" \
            --text="Choose a WSL distribution to run:" \
            --column="ID" --column="Distribution" --column="Type" --column="Location" \
            --hide-column=1 \
            --width=900 --height=450 \
            --extra-button="Browse VHDX…" 2>/dev/null) || true

        if [ "$selected" = "Browse VHDX…" ]; then
            selected_vhdx="$(browse_vhdx || true)"
            if [ -n "$selected_vhdx" ]; then
                if [ -f "$LSL_SCRIPT" ]; then
                    exec "$LSL_SCRIPT" --vhdx "$selected_vhdx" "$@"
                fi
                show_error "lsl script not found at $LSL_SCRIPT"
                exit 1
            fi
            exit 0
        fi
        
        if [ -z "$selected" ]; then
            exit 0
        fi

        # Zenity may return a full row like "1|Ubuntu|VHDX|/path" (even when hide/print
        # options vary between versions). Only the first field is the numeric index.
        local selected_id="${selected%%|*}"
        selected_id="${selected_id//$'\r'/}"
        if ! [[ "$selected_id" =~ ^[0-9]+$ ]]; then
            show_error "Unexpected selection value from picker:\n$selected"
            exit 1
        fi

        if [ "$selected_id" -lt 1 ] || [ "$selected_id" -gt "${#distro_names[@]}" ]; then
            show_error "Invalid selection index:\n$selected_id"
            exit 1
        fi

        selected_name="${distro_names[$((selected_id - 1))]}"
        
    elif [ "$GUI_TOOL" = "dialog" ]; then
        # Use dialog menu
        local dialog_items=("${menu_items[@]}")
        dialog_items+=("B" "Browse VHDX...")
        selected=$(dialog --menu "Select WSL Distribution" 20 60 12 "${dialog_items[@]}" 2>&1 >/dev/tty) || true

        if [ "$selected" = "B" ]; then
            selected_vhdx="$(browse_vhdx || true)"
            if [ -n "$selected_vhdx" ]; then
                if [ -f "$LSL_SCRIPT" ]; then
                    exec "$LSL_SCRIPT" --vhdx "$selected_vhdx" "$@"
                fi
                show_error "lsl script not found at $LSL_SCRIPT"
                exit 1
            fi
            exit 0
        fi
        
        if [ -z "$selected" ] || [ "$selected" -lt 1 ] || [ "$selected" -gt "${#distro_names[@]}" ]; then
            exit 0
        fi
        
        selected_name="${distro_names[$((selected - 1))]}"
        
    elif [ "$GUI_TOOL" = "whiptail" ]; then
        # Use whiptail menu
        local whiptail_items=("${menu_items[@]}")
        whiptail_items+=("B" "Browse VHDX...")
        selected=$(whiptail --menu "Select WSL Distribution" 20 60 12 "${whiptail_items[@]}" 3>&1 1>&2 2>&3) || true

        if [ "$selected" = "B" ]; then
            selected_vhdx="$(browse_vhdx || true)"
            if [ -n "$selected_vhdx" ]; then
                if [ -f "$LSL_SCRIPT" ]; then
                    exec "$LSL_SCRIPT" --vhdx "$selected_vhdx" "$@"
                fi
                show_error "lsl script not found at $LSL_SCRIPT"
                exit 1
            fi
            exit 0
        fi
        
        if [ -z "$selected" ] || [ "$selected" -lt 1 ] || [ "$selected" -gt "${#distro_names[@]}" ]; then
            exit 0
        fi
        
        selected_name="${distro_names[$((selected - 1))]}"
        
    else
        # Fallback to text menu
        echo "Available WSL distributions:"
        echo ""
        for i in "${!distro_names[@]}"; do
            echo "$((i + 1)). ${distro_names[$i]}"
        done
        echo "B. Browse VHDX..."
        echo ""
        read -p "Select distribution (1-${#distro_names[@]}) or B: " selected

        if [ "$selected" = "B" ] || [ "$selected" = "b" ]; then
            selected_vhdx="$(browse_vhdx || true)"
            if [ -n "$selected_vhdx" ]; then
                if [ -f "$LSL_SCRIPT" ]; then
                    exec "$LSL_SCRIPT" --vhdx "$selected_vhdx" "$@"
                fi
                show_error "lsl script not found at $LSL_SCRIPT"
                exit 1
            fi
            exit 0
        fi
        
        if [ -z "$selected" ] || [ "$selected" -lt 1 ] || [ "$selected" -gt "${#distro_names[@]}" ]; then
            echo "Invalid selection"
            exit 1
        fi
        
        selected_name="${distro_names[$((selected - 1))]}"
    fi
    
    if [ -z "$selected_name" ]; then
        show_error "No distribution selected"
        exit 1
    fi
    
    # Launch lsl with the selected distribution
    if [ -f "$LSL_SCRIPT" ]; then
        # Use the lsl script with the selected distribution
        exec "$LSL_SCRIPT" -d "$selected_name" "$@"
    else
        show_error "lsl script not found at $LSL_SCRIPT"
        exit 1
    fi
}

# Run main function
main "$@"
