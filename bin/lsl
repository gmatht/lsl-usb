#!/bin/bash
# lsl - Linux Services for Linux - WSL emulator
# Mounts VHDX files and chroots into WSL distributions

WSL_REPORT="${WSL_REPORT:-/tmp/wsl}"
LSL_MOUNT_BASE="/tmp/lsl_mounts"
LSL_SCRIPT_DIR="$(cd -- "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
# shellcheck source=/dev/null
. "$LSL_SCRIPT_DIR/lsl-common.sh"

run_privileged() {
    if [ "${EUID:-$(id -u)}" -eq 0 ]; then
        "$@"
        return $?
    fi

    if command -v sudo >/dev/null 2>&1; then
        sudo "$@"
        return $?
    fi

    return 1
}

# Function to ensure WSL report exists by running detect-wsl if needed
ensure_wsl_report() {
    if [ ! -f "$WSL_REPORT" ] || [ ! -s "$WSL_REPORT" ] || grep -q "No WSL distributions found" "$WSL_REPORT" 2>/dev/null; then
        # Prefer mounting Windows volumes (C:, D:) and then detecting.
        if command -v wsl-boot-setup >/dev/null 2>&1; then
            echo "WSL report missing/empty. Running wsl-boot-setup..." >&2
            run_privileged wsl-boot-setup >/dev/null 2>&1 || true
        elif [ -n "${LSL_SCRIPT_DIR:-}" ] && [ -x "$LSL_SCRIPT_DIR/wsl-boot-setup" ]; then
            echo "WSL report missing/empty. Running wsl-boot-setup..." >&2
            run_privileged "$LSL_SCRIPT_DIR/wsl-boot-setup" >/dev/null 2>&1 || true
        elif [ -x "/cdrom/bin/wsl-boot-setup" ]; then
            echo "WSL report missing/empty. Running wsl-boot-setup..." >&2
            run_privileged /cdrom/bin/wsl-boot-setup >/dev/null 2>&1 || true
        fi

        # Fallback: just run detect-wsl if available
        if command -v detect-wsl >/dev/null 2>&1; then
            echo "WSL report missing/empty. Running detect-wsl..." >&2
            run_privileged detect-wsl >/dev/null 2>&1 || true
        elif [ -n "${LSL_SCRIPT_DIR:-}" ] && [ -x "$LSL_SCRIPT_DIR/detect-wsl" ]; then
            echo "WSL report missing/empty. Running detect-wsl..." >&2
            run_privileged "$LSL_SCRIPT_DIR/detect-wsl" >/dev/null 2>&1 || true
        elif [ -x "/cdrom/bin/detect-wsl" ]; then
            echo "WSL report missing/empty. Running detect-wsl..." >&2
            run_privileged /cdrom/bin/detect-wsl >/dev/null 2>&1 || true
        fi
    fi
}

# Parse command line arguments
DISTRO=""
LIST_ONLY=false
LIST_VHDX=false
COMMAND=""
VHDX_OVERRIDE=""
LSL_TMPFS_OVERLAY=false

while [[ $# -gt 0 ]]; do
    case $1 in
        -d|--distribution)
            DISTRO="$2"
            shift 2
            ;;
        -v|--vhdx)
            VHDX_OVERRIDE="$2"
            shift 2
            ;;
        --tmpfs-overlay)
            LSL_TMPFS_OVERLAY=true
            shift
            ;;
        -l|--list)
            LIST_ONLY=true
            shift
            ;;
        --list-vhdx)
            LIST_VHDX=true
            shift
            ;;
        -h|--help)
            echo "Usage: lsl [OPTIONS] [COMMAND]"
            echo ""
            echo "Options:"
            echo "  -d, --distribution NAME  Specify WSL distribution name"
            echo "  -v, --vhdx FILE          Specify a VHDX file to mount (bypasses detection)"
            echo "      --tmpfs-overlay      RAM-backed overlay on VHDX root (session writes; optional on ro images)"
            echo "  -l, --list               List available WSL distributions"
            echo "      --list-vhdx          List VHDX paths saved from lsl-gui (one path per line)"
            echo "  -h, --help               Show this help message"
            echo ""
            echo "Examples:"
            echo "  lsl                      Enter default WSL distribution"
            echo "  lsl -d Ubuntu            Enter Ubuntu distribution"
            echo "  lsl --vhdx /path/to/ext4.vhdx   Enter a VHDX directly"
            echo "  sudo lsl --tmpfs-overlay --vhdx /path/disk.vhdx   Session in RAM over VHDX (no writes to image)"
            echo "  lsl /path/to/disk.vhdx   Same if the path exists (convenience)"
            echo "  lsl -l                   List all available distributions"
            echo "  lsl --list-vhdx          Print saved VHDX paths"
            echo "  lsl bash                 Run bash in default distribution"
            exit 0
            ;;
        *)
            # A lone existing *.vhdx path is the image to mount, not a shell command.
            if [ -z "$COMMAND" ] && [ -n "$1" ] && [[ "$1" == *.vhdx ]] && [ -f "$1" ]; then
                VHDX_OVERRIDE="$1"
                shift
                [ $# -gt 0 ] && COMMAND="$*"
                break
            fi
            if [ -z "$COMMAND" ]; then
                COMMAND="$*"
            fi
            break
            ;;
    esac
done

# Function to parse WSL report and extract VHDX/distro mappings (merges lsl-gui–saved VHDX paths).
parse_wsl_report() {
    local vhdx_file=""
    local rootfs_path=""
    local distro_name=""
    local registry_name=""

    ensure_wsl_report

    local report_ok=0
    if [ -f "$WSL_REPORT" ] && [ -s "$WSL_REPORT" ] && ! grep -q "No WSL distributions found" "$WSL_REPORT" 2>/dev/null; then
        report_ok=1
    fi

    flush_entry() {
        local name=""

        if [ -n "$registry_name" ]; then
            name="$registry_name"
        fi

        if [ -n "$rootfs_path" ]; then
            if [[ "$rootfs_path" =~ Packages/([^/]+)/LocalState/rootfs$ ]]; then
                name="${BASH_REMATCH[1]}"
            elif [[ "$rootfs_path" =~ /([^/]+)/rootfs$ ]]; then
                name="${BASH_REMATCH[1]}"
            elif [[ "$rootfs_path" =~ distros/([^/]+) ]]; then
                name="${BASH_REMATCH[1]}"
            else
                name="$(basename "$(dirname "$rootfs_path")")"
            fi
        elif [ -n "$vhdx_file" ]; then
            if [[ "$vhdx_file" =~ Packages/([^/]+)/LocalState/ ]]; then
                name="${BASH_REMATCH[1]}"
            else
                name="$(basename "$vhdx_file")"
            fi
        fi

        if [ -z "$name" ]; then
            return 0
        fi

        # Emit even when paths are missing on disk (list -l / GUI show unavailable).
        if [ -n "$vhdx_file" ]; then
            echo "$name|$vhdx_file|$rootfs_path"
            return 0
        fi

        if [ -n "$rootfs_path" ]; then
            echo "$name||$rootfs_path"
            return 0
        fi

        return 0
    }

    {
        if [ "$report_ok" -eq 1 ]; then
            while IFS= read -r line; do
                if [[ "$line" =~ ^Found\ ext4\.vhdx:\ (.+)$ ]]; then
                    vhdx_file="${BASH_REMATCH[1]}"
                elif [[ "$line" =~ ^Found\ vhdx:\ (.+)$ ]]; then
                    vhdx_file="${BASH_REMATCH[1]}"
                elif [[ "$line" =~ ^WSL\ (Distro|Custom|LXSS)\ vhdx:\ (.+)$ ]]; then
                    vhdx_file="${BASH_REMATCH[2]}"
                elif [[ "$line" =~ ^WSL\ Registry\ vhdx:\ (.+)$ ]]; then
                    vhdx_file="${BASH_REMATCH[1]}"
                elif [[ "$line" =~ ^WSL\ Registry\ name:\ (.+)$ ]]; then
                    registry_name="${BASH_REMATCH[1]}"
                elif [[ "$line" =~ ^WSL\ Registry\ rootfs:\ (.+)$ ]]; then
                    rootfs_path="${BASH_REMATCH[1]}"
                elif [[ "$line" =~ ^WSL\ (Distro|Custom|LXSS)\ rootfs:\ (.+)$ ]]; then
                    rootfs_path="${BASH_REMATCH[2]}"
                elif [[ "$line" == "---" ]]; then
                    flush_entry
                    vhdx_file=""
                    rootfs_path=""
                    distro_name=""
                    registry_name=""
                fi
            done <"$WSL_REPORT"
            flush_entry
        fi
        lsl_vhdx_saved_distro_lines
    } | lsl_dedupe_distro_lines
}

# Function to list available distributions
list_distros() {
    echo "Available WSL distributions:"
    echo ""
    local count=0
    while IFS='|' read -r name vhdx rootfs; do
        count=$((count + 1))
        echo "  $count. $name"
        if [ -n "$vhdx" ] && [ -f "$vhdx" ]; then
            echo "     VHDX: $vhdx"
        else
            echo "     VHDX: (not available)"
        fi
        if [ -n "$rootfs" ] && [ -d "$rootfs" ]; then
            echo "     Rootfs: $rootfs"
        else
            echo "     Rootfs: (not available)"
        fi
        echo ""
    done < <(parse_wsl_report)
    
    if [ $count -eq 0 ]; then
        # Try to refresh the report and retry once.
        ensure_wsl_report
        while IFS='|' read -r name vhdx rootfs; do
            count=$((count + 1))
            echo "  $count. $name"
            if [ -n "$vhdx" ] && [ -f "$vhdx" ]; then
                echo "     VHDX: $vhdx"
            else
                echo "     VHDX: (not available)"
            fi
            if [ -n "$rootfs" ] && [ -d "$rootfs" ]; then
                echo "     Rootfs: $rootfs"
            else
                echo "     Rootfs: (not available)"
            fi
            echo ""
        done < <(parse_wsl_report)

        if [ $count -eq 0 ]; then
            echo "No WSL distributions found."
            echo "Tried mounting Windows partitions automatically and rerunning detection." >&2
            echo "If this still fails, set LSL_WIN_C_DEV (and optionally LSL_WIN_D_DEV) and run: wsl-boot-setup" >&2
            return 1
        fi
    fi
    return 0
}

# Function to find VHDX by distro name
find_vhdx_by_distro() {
    local search_name="$1"
    while IFS='|' read -r name vhdx rootfs; do
        if [[ "$name" == "$search_name" ]] || [[ "$name" =~ $search_name ]]; then
            echo "$vhdx|$rootfs"
            return 0
        fi
    done < <(parse_wsl_report)
    return 1
}

# Function to get first available VHDX
get_first_vhdx() {
    local first=$(parse_wsl_report | head -n 1)
    if [ -n "$first" ]; then
        IFS='|' read -r name vhdx rootfs <<< "$first"
        echo "$vhdx|$rootfs"
        return 0
    fi
    return 1
}

# True if path looks like a Linux root (WSL often uses ./rootfs/).
lsl_is_linux_root() {
    local r="$1"
    [ -d "$r" ] || return 1
    if [ ! -f "$r/etc/os-release" ] && [ ! -f "$r/usr/lib/os-release" ]; then
        return 1
    fi
    if [ ! -e "$r/bin/bash" ] && [ ! -e "$r/usr/bin/bash" ]; then
        return 1
    fi
    return 0
}

# Print absolute root path for chroot (may be .../rootfs).
lsl_resolve_linux_root() {
    local base="$1"
    if lsl_is_linux_root "$base"; then
        echo "$base"
        return 0
    fi
    if [ -d "$base/rootfs" ] && lsl_is_linux_root "$base/rootfs"; then
        echo "$base/rootfs"
        return 0
    fi
    if [ -d "$base/root" ] && lsl_is_linux_root "$base/root"; then
        echo "$base/root"
        return 0
    fi
    return 1
}

# Prefer Linux data partitions over EFI (p1 is often vfat on multi-part images).
lsl_nbd_partition_candidates() {
    local nbd="$1"
    local p t
    local -a pref=() rest=()
    shopt -s nullglob
    for p in "${nbd}"p*; do
        [ -b "$p" ] || continue
        t="$(blkid -o value -s TYPE "$p" 2>/dev/null || true)"
        case "$t" in
            ext4|btrfs|xfs) pref+=("$p") ;;
            *) rest+=("$p") ;;
        esac
    done
    shopt -u nullglob
    printf '%s\n' "${pref[@]}" "${rest[@]}"
}

# Mount VHDX: try default appliance, then LIBGUESTFS_BACKEND=direct, then sudo (supermin often fails without KVM).
lsl_mount_vhdx() {
    local vhdx_file="$1"
    local mount_point="$2"
    local part

    if guestmount -a "$vhdx_file" -i "$mount_point" 2>/dev/null; then
        return 0
    fi
    if LIBGUESTFS_BACKEND=direct guestmount -a "$vhdx_file" -i "$mount_point" 2>/dev/null; then
        echo "(guestmount: used LIBGUESTFS_BACKEND=direct)" >&2
        return 0
    fi
    if run_privileged guestmount -a "$vhdx_file" -i "$mount_point" 2>/dev/null; then
        echo "(guestmount: used sudo)" >&2
        return 0
    fi
    if run_privileged env LIBGUESTFS_BACKEND=direct guestmount -a "$vhdx_file" -i "$mount_point" 2>/dev/null; then
        echo "(guestmount: used sudo + LIBGUESTFS_BACKEND=direct)" >&2
        return 0
    fi

    for part in /dev/sda1 /dev/sda2; do
        if guestmount -a "$vhdx_file" -m "$part" "$mount_point" 2>/dev/null; then
            echo "Mounted partition $part" >&2
            return 0
        fi
        if LIBGUESTFS_BACKEND=direct guestmount -a "$vhdx_file" -m "$part" "$mount_point" 2>/dev/null; then
            echo "Mounted partition $part (direct)" >&2
            return 0
        fi
        if run_privileged guestmount -a "$vhdx_file" -m "$part" "$mount_point" 2>/dev/null; then
            echo "Mounted partition $part (sudo)" >&2
            return 0
        fi
        if run_privileged env LIBGUESTFS_BACKEND=direct guestmount -a "$vhdx_file" -m "$part" "$mount_point" 2>/dev/null; then
            echo "Mounted partition $part (sudo+direct)" >&2
            return 0
        fi
    done

    # No libguestfs appliance (supermin often breaks without KVM): use qemu-nbd + mount.
    if lsl_mount_vhdx_qemu_nbd "$vhdx_file" "$mount_point"; then
        return 0
    fi
    return 1
}

# Mount VHDX via qemu-nbd (no libguestfs). Requires qemu-utils, nbd module, and root/sudo.
lsl_mount_vhdx_qemu_nbd() {
    local vhdx_file="$1"
    local mount_point="$2"
    local nbd part

    command -v qemu-nbd >/dev/null 2>&1 || return 1
    run_privileged modprobe nbd max_part=16 2>/dev/null || true

    for nbd in /dev/nbd{0..15}; do
        [ -b "$nbd" ] || continue
        if run_privileged qemu-nbd --connect="$nbd" -f vhdx "$vhdx_file" 2>/dev/null; then
            run_privileged partprobe "$nbd" 2>/dev/null || true
            sleep 0.3
            local try_parts
            try_parts="$(lsl_nbd_partition_candidates "$nbd")"
            if [ -z "$try_parts" ] && [ -b "$nbd" ]; then
                try_parts="$nbd"
            fi
            while IFS= read -r part; do
                [ -n "$part" ] || continue
                [ -b "$part" ] || continue
                run_privileged mount "$part" "$mount_point" 2>/dev/null || continue
                if lsl_resolve_linux_root "$mount_point" >/dev/null 2>&1; then
                    echo "(mounted via qemu-nbd: $part)" >&2
                    return 0
                fi
                run_privileged umount "$mount_point" 2>/dev/null || true
            done <<<"$try_parts"
            run_privileged qemu-nbd --disconnect="$nbd" 2>/dev/null || run_privileged qemu-nbd -d "$nbd" 2>/dev/null || true
        fi
    done
    return 1
}

# True if the filesystem containing PATH is mounted read-only.
lsl_path_is_readonly() {
    local opts
    opts="$(findmnt -n -o OPTIONS -T "$1" 2>/dev/null)" || return 1
    case ",$opts," in
        *,ro,*) return 0 ;;
        *) return 1 ;;
    esac
}

# RAM-backed overlay on read-only root. Sets LSL_VHDX_OVL_BASE for cleanup; prints merged path.
lsl_vhdx_tmpfs_overlay_mount() {
    local lower="$1"
    local size_mib="${2:-4096}"
    local merged
    LSL_VHDX_OVL_BASE=""
    LSL_VHDX_OVL_BASE="$LSL_MOUNT_BASE/ovl_${RANDOM}_$$"
    merged="$LSL_VHDX_OVL_BASE/merged"
    mkdir -p "$LSL_VHDX_OVL_BASE" || return 1
    if ! run_privileged mount -t tmpfs -o "size=${size_mib}M" tmpfs "$LSL_VHDX_OVL_BASE"; then
        rmdir "$LSL_VHDX_OVL_BASE" 2>/dev/null || true
        LSL_VHDX_OVL_BASE=""
        return 1
    fi
    mkdir -p "$LSL_VHDX_OVL_BASE/upper" "$LSL_VHDX_OVL_BASE/work" "$merged" || {
        run_privileged umount "$LSL_VHDX_OVL_BASE" 2>/dev/null || true
        LSL_VHDX_OVL_BASE=""
        return 1
    }
    if ! run_privileged mount -t overlay overlay -o "lowerdir=$lower,upperdir=$LSL_VHDX_OVL_BASE/upper,workdir=$LSL_VHDX_OVL_BASE/work" "$merged"; then
        run_privileged umount "$LSL_VHDX_OVL_BASE" 2>/dev/null || true
        LSL_VHDX_OVL_BASE=""
        return 1
    fi
    printf '%s\n' "$merged"
}

# Function to mount VHDX and chroot
mount_and_chroot() {
    local vhdx_file="$1"
    local rootfs_path="$2"
    local root_fs=""
    local vhdx_mounted=""
    
    # If VHDX file is provided, mount it
    if [ -n "$vhdx_file" ] && [ -f "$vhdx_file" ]; then
        local mount_point="$LSL_MOUNT_BASE/$(basename "$vhdx_file" .vhdx)"
        
        # Create mount point
        mkdir -p "$mount_point"
        
        # Check if already mounted
        if mountpoint -q "$mount_point" 2>/dev/null; then
            echo "VHDX already mounted at $mount_point"
            root_fs="$mount_point"
            vhdx_mounted="$mount_point"
        else
            # Mount VHDX using guestmount
            echo "Mounting VHDX: $vhdx_file"
            
            if lsl_mount_vhdx "$vhdx_file" "$mount_point"; then
                echo "Successfully mounted at $mount_point"
                root_fs="$mount_point"
                vhdx_mounted="$mount_point"
            else
                echo "Error: Failed to mount VHDX file (libguestfs and qemu-nbd)" >&2
                echo "Image info (no libguestfs):" >&2
                if command -v qemu-img >/dev/null 2>&1; then
                    run_privileged qemu-img info "$vhdx_file" 2>&1 | head -35 || true
                fi
                file "$vhdx_file" 2>/dev/null || true
                echo "" >&2
                echo "Ensure: sudo modprobe nbd; qemu-nbd and qemu-img (qemu-utils); disk not in use by WSL/Hyper-V." >&2
                echo "If libguestfs alone fails (supermin), lsl now tries qemu-nbd automatically — use: sudo lsl -v \"$vhdx_file\"" >&2
                echo "Falling back to rootfs path if available..." >&2
                # Fall through to try rootfs_path
            fi
        fi
        
        # Resolve WSL layout (./rootfs) and ensure we have a real Linux root
        if [ -n "$root_fs" ]; then
            local resolved=""
            if resolved="$(lsl_resolve_linux_root "$root_fs")"; then
                root_fs="$resolved"
            else
                echo "Error: Mounted image has no usable Linux root (need /etc/os-release and bash; try another partition or WSL layout under rootfs/)." >&2
                return 1
            fi
        fi
    fi
    
    # Fallback to rootfs_path if VHDX mounting failed or not available
    if [ -z "$root_fs" ] && [ -n "$rootfs_path" ] && [ -d "$rootfs_path" ]; then
        echo "Using rootfs path directly: $rootfs_path"
        root_fs="$rootfs_path"
        local resolved=""
        if resolved="$(lsl_resolve_linux_root "$root_fs")"; then
            root_fs="$resolved"
        fi
    fi
    
    if [ -z "$root_fs" ] || [ ! -d "$root_fs" ]; then
        echo "Error: Could not determine root filesystem location" >&2
        return 1
    fi

    # VHDX: honor --tmpfs-overlay always; if ro and no overlay, suggest the flag
    LSL_VHDX_OVL_BASE=""
    if [ -n "$vhdx_mounted" ]; then
        if [ "${LSL_TMPFS_OVERLAY:-false}" = true ]; then
            local mib="${LSL_VHDX_OVERLAY_MIB:-4096}"
            local merged
            merged="$(lsl_vhdx_tmpfs_overlay_mount "$root_fs" "$mib")" || {
                echo "Error: tmpfs overlay failed (need overlay filesystem support and root/sudo)." >&2
                return 1
            }
            root_fs="$merged"
            echo "tmpfs overlay active (upper layer up to ${mib}MiB; changes are discarded when you exit)." >&2
        elif lsl_path_is_readonly "$root_fs"; then
            echo "" >&2
            echo "Note: This VHDX is mounted read-only — the disk image will not be written." >&2
            echo "For a writable session using RAM only (nothing persisted to the VHDX), run:" >&2
            echo "  sudo lsl --tmpfs-overlay --vhdx \"$vhdx_file\"" >&2
            echo "Optional: LSL_VHDX_OVERLAY_MIB=8192 caps the writable overlay size (mebibytes)." >&2
            echo "" >&2
        fi
    fi
    
    if ! lsl_is_linux_root "$root_fs"; then
        echo "Warning: Root may be incomplete (missing etc/os-release or bash)" >&2
    fi
    
    # Setup bind mounts for chroot
    mount --bind /proc "$root_fs/proc" 2>/dev/null
    mount --bind /dev "$root_fs/dev" 2>/dev/null
    mount --bind /sys "$root_fs/sys" 2>/dev/null
    mount --bind /dev/pts "$root_fs/dev/pts" 2>/dev/null
    
    # Copy resolv.conf for network
    if [ -f /etc/resolv.conf ]; then
        cp /etc/resolv.conf "$root_fs/etc/resolv.conf" 2>/dev/null || true
    fi
    
    # Chroot and execute command (prefer /usr/bin/bash — some roots only have that)
    if [ -n "$COMMAND" ]; then
        chroot "$root_fs" $COMMAND
    else
        echo "Entering WSL distribution..."
        echo "Type 'exit' to leave"
        if [ -x "$root_fs/usr/bin/bash" ]; then
            chroot "$root_fs" /usr/bin/bash -l
        elif [ -x "$root_fs/bin/bash" ]; then
            chroot "$root_fs" /bin/bash -l
        elif [ -x "$root_fs/usr/bin/sh" ]; then
            chroot "$root_fs" /usr/bin/sh -l
        else
            chroot "$root_fs" /bin/sh -l
        fi
    fi
    
    local exit_code=$?
    
    # Cleanup bind mounts
    umount "$root_fs/proc" 2>/dev/null || true
    umount "$root_fs/dev/pts" 2>/dev/null || true
    umount "$root_fs/dev" 2>/dev/null || true
    umount "$root_fs/sys" 2>/dev/null || true

    if [ -n "${LSL_VHDX_OVL_BASE:-}" ]; then
        run_privileged umount "$root_fs" 2>/dev/null || true
        run_privileged umount "$LSL_VHDX_OVL_BASE" 2>/dev/null || true
        LSL_VHDX_OVL_BASE=""
    fi
    
    # Optionally unmount VHDX (comment out to keep mounted)
    # guestunmount "$mount_point" 2>/dev/null || umount "$mount_point" 2>/dev/null || true
    
    return $exit_code
}

# Main execution
lsl_load_config 2>/dev/null || true
if [ "$LIST_VHDX" = true ]; then
    lsl_vhdx_paths_stdout
    exit 0
fi

if [ "$LIST_ONLY" = true ]; then
    list_distros
    exit $?
fi

# Direct VHDX mount mode (bypass detection/report)
if [ -n "$VHDX_OVERRIDE" ]; then
    if [ ! -f "$VHDX_OVERRIDE" ]; then
        echo "Error: VHDX file not found: $VHDX_OVERRIDE" >&2
        exit 1
    fi
    mount_and_chroot "$VHDX_OVERRIDE" ""
    exit $?
fi

# Find VHDX file
VHDX_INFO=""
if [ -n "$DISTRO" ]; then
    VHDX_INFO=$(find_vhdx_by_distro "$DISTRO")
    if [ -z "$VHDX_INFO" ]; then
        echo "Error: Distribution '$DISTRO' not found" >&2
        echo ""
        list_distros
        exit 1
    fi
else
    VHDX_INFO=$(get_first_vhdx)
    if [ -z "$VHDX_INFO" ]; then
        echo "Error: No WSL distributions found" >&2
        echo "Run onboot.sh first to detect WSL distributions" >&2
        exit 1
    fi
fi

IFS='|' read -r VHDX_FILE ROOTFS_PATH <<< "$VHDX_INFO"

# Validate that we have either VHDX or rootfs
if [ -z "$VHDX_FILE" ] && [ -z "$ROOTFS_PATH" ]; then
    echo "Error: No valid VHDX or rootfs found" >&2
    exit 1
fi

if [ -n "$VHDX_FILE" ] && [ ! -f "$VHDX_FILE" ]; then
    echo "Warning: VHDX file not found: $VHDX_FILE" >&2
    echo "Will try to use rootfs path instead" >&2
    VHDX_FILE=""
fi

# Mount and chroot
mount_and_chroot "$VHDX_FILE" "$ROOTFS_PATH"

