#!/bin/bash
# Periodically grow loop-backed home.btrfs on HDD when free space is low.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
. "$SCRIPT_DIR/lsl-common.sh"

lsl_load_config

if lsl_is_usb_mode; then
    exit 0
fi

MIN_PCT="${LSL_BTRFS_MIN_FREE_PCT:-10}"
CHUNK_MIB="${LSL_BTRFS_GROW_CHUNK_MIB:-1024}"

# Args: mountpoint image_path label
free_pct() {
    if ! mountpoint -q "$1" 2>/dev/null; then
        echo ""
        return 1
    fi
    df -P "$1" 2>/dev/null | awk 'NR==2 { gsub(/%/,"",$5); print 100 - $5 }'
}

try_grow() {
    local mp="$1" img="$2" label="$3"
    local fp
    [ -f "$img" ] || return 0
    mountpoint -q "$mp" 2>/dev/null || return 0
    fp="$(free_pct "$mp")" || return 0
    case "$fp" in
        ''|*[!0-9]*) return 0 ;;
    esac
    if [ "$fp" -gt "$MIN_PCT" ]; then
        return 0
    fi

    echo "lsl-btrfs-growd: low free space on ${label} (${fp}% ≤ ${MIN_PCT}%), growing ${img} by ${CHUNK_MIB}MiB…"
    btrfs filesystem sync "$mp" 2>/dev/null || true
    if ! truncate -s "+${CHUNK_MIB}M" "$img"; then
        echo "lsl-btrfs-growd: truncate failed (${label})" >&2
        return 0
    fi
    if ! btrfs filesystem resize max "$mp"; then
        echo "lsl-btrfs-growd: btrfs resize failed (${label})" >&2
    fi
    df -h "$mp" 2>/dev/null || true
}

while true; do
    lsl_load_config
    if lsl_is_usb_mode; then
        exit 0
    fi
    try_grow /home "$(lsl_home_btrfs_path)" home
    try_grow "${LSL_CACHE_MOUNT:-/mnt/lsl-cache}" "$(lsl_cache_btrfs_path)" cache
    sleep 60
done
