#!/bin/bash
# detect-wsl - Detect WSL rootfs directories on mounted Windows partitions
# Creates /tmp/wsl report file for use by lsl and lsl-gui (VHDX paths come from lsl-gui browse / lsl state, not scanning).

WSL_REPORT="${WSL_REPORT:-/tmp/wsl}"

# Clear existing report
> "$WSL_REPORT"

win_path_to_linux() {
    # Convert a Windows path like C:\Foo\Bar to /mnt/c/Foo/Bar
    local win="$1"

    if [[ "$win" =~ ^([A-Za-z]):\\\\(.*)$ ]]; then
        local drive="${BASH_REMATCH[1],,}"
        local rest="${BASH_REMATCH[2]}"
        rest="${rest//\\\\//}"
        echo "/mnt/$drive/$rest"
        return 0
    fi

    if [[ "$win" =~ ^([A-Za-z]):/(.*)$ ]]; then
        local drive="${BASH_REMATCH[1],,}"
        local rest="${BASH_REMATCH[2]}"
        echo "/mnt/$drive/$rest"
        return 0
    fi

    return 1
}

detect_wsl_from_ntuser() {
    local ntuser="$1"

    if command -v hivexregedit >/dev/null 2>&1; then
        local distro_name=""
        local base_path=""

        hivexregedit --export "$ntuser" '\\Software\\Microsoft\\Windows\\CurrentVersion\\Lxss' 2>/dev/null | while IFS= read -r line; do
            if [[ "$line" =~ ^\"DistributionName\"= ]]; then
                distro_name="${line#*=}"
                distro_name="${distro_name#\"}"
                distro_name="${distro_name%\"}"
            elif [[ "$line" =~ ^\"BasePath\"= ]]; then
                base_path="${line#*=}"
                base_path="${base_path#\"}"
                base_path="${base_path%\"}"

                if [ -n "$base_path" ]; then
                    local linux_base=""
                    linux_base="$(win_path_to_linux "$base_path" 2>/dev/null || true)"

                    if [ -n "$linux_base" ] && [ -d "$linux_base/rootfs" ]; then
                        if [ -n "$distro_name" ]; then
                            echo "WSL Registry name: $distro_name" >> "$WSL_REPORT"
                        fi
                        echo "WSL Registry rootfs: $linux_base/rootfs" >> "$WSL_REPORT"
                        echo "---" >> "$WSL_REPORT"
                    fi
                fi

                distro_name=""
                base_path=""
            fi
        done

        return 0
    fi

    command -v strings >/dev/null 2>&1 || return 0

    local distro_name=""
    local base_path=""
    local want_name=0
    local want_base=0

    strings -el "$ntuser" 2>/dev/null | while IFS= read -r s; do
        if [ "$s" = "DistributionName" ]; then
            want_name=1
            continue
        fi
        if [ "$s" = "BasePath" ]; then
            want_base=1
            continue
        fi

        if [ "$want_name" -eq 1 ]; then
            distro_name="$s"
            want_name=0
            continue
        fi

        if [ "$want_base" -eq 1 ]; then
            base_path="$s"
            want_base=0

            if [[ "$base_path" =~ ^[A-Za-z]:\\\\ ]] || [[ "$base_path" =~ ^[A-Za-z]:/ ]]; then
                local linux_base=""
                linux_base="$(win_path_to_linux "$base_path" 2>/dev/null || true)"

                if [ -n "$linux_base" ] && [ -d "$linux_base/rootfs" ]; then
                    if [ -n "$distro_name" ]; then
                        echo "WSL Registry name: $distro_name" >> "$WSL_REPORT"
                    fi
                    echo "WSL Registry rootfs: $linux_base/rootfs" >> "$WSL_REPORT"
                    echo "---" >> "$WSL_REPORT"
                fi
            fi

            distro_name=""
            base_path=""
        fi
    done
}

detect_wsl_on_partition() {
    local base_path="$1"
    local users_dir="$base_path/Users"

    if [ ! -d "$users_dir" ]; then
        return 0
    fi

    find "$users_dir" -maxdepth 1 -type d -name "*" 2>/dev/null | while read -r user_dir; do
        [ "$user_dir" = "$users_dir" ] && continue

        local appdata="$user_dir/AppData/Local"
        if [ ! -d "$appdata" ]; then
            continue
        fi

        if [ -f "$user_dir/NTUSER.DAT" ]; then
            detect_wsl_from_ntuser "$user_dir/NTUSER.DAT"
        fi

        find "$appdata/Packages" -type d -path "*/LocalState/rootfs" 2>/dev/null | while read -r rootfs_path; do
            local localstate_dir
            localstate_dir="$(dirname "$rootfs_path")"
            local distro_type="Distro"

            if [[ "$localstate_dir" =~ Packages/([^/]+)/LocalState$ ]]; then
                local package_name="${BASH_REMATCH[1]}"
                if [[ "$package_name" =~ ^CanonicalGroupLimited ]] || [[ "$package_name" =~ ^Microsoft\.WindowsSubsystemLinux ]]; then
                    distro_type="Distro"
                else
                    distro_type="Custom"
                fi
            fi

            echo "WSL $distro_type rootfs: $rootfs_path" >> "$WSL_REPORT"
            echo "---" >> "$WSL_REPORT"
        done

        if [ -d "$appdata/lxss/rootfs" ]; then
            echo "WSL LXSS rootfs: $appdata/lxss/rootfs" >> "$WSL_REPORT"
            echo "---" >> "$WSL_REPORT"
        fi

        find "$appdata" -type d -path "*/distros/*/rootfs" 2>/dev/null | while read -r distro_rootfs; do
            echo "WSL Custom rootfs: $distro_rootfs" >> "$WSL_REPORT"
            echo "---" >> "$WSL_REPORT"
        done
    done
}

print_shortnames() {
    if [ ! -s "$WSL_REPORT" ]; then
        return 0
    fi

    awk '
        /^WSL Registry name: / { sub(/^WSL Registry name: /,""); n=$0; next }
        /^WSL (Distro|Custom|LXSS) rootfs: / { sub(/^WSL (Distro|Custom|LXSS) rootfs: /,""); r=$0; next }
        /^WSL Registry rootfs: / { sub(/^WSL Registry rootfs: /,""); r=$0; next }
        /^---$/ {
            name=""
            if (n != "") name=n
            else if (r != "") {
                if (index(r, "/Packages/") > 0 && index(r, "/LocalState/") > 0) {
                    split(r, a, "/Packages/");
                    if (length(a) >= 2) {
                        split(a[2], b, "/");
                        if (length(b) >= 1 && b[1] != "") name=b[1];
                    }
                }
                if (name == "") {
                    name=r
                    sub(/^.*\//, "", name);
                }
            }
            if (name != "") names[name]=1
            n=""
            r=""
            next
        }
        END {
            name=""
            if (n != "") name=n
            else if (r != "") {
                name=r
                sub(/^.*\//, "", name);
            }
            if (name != "") names[name]=1
            for (k in names) print k
        }
    ' "$WSL_REPORT" | sort
}

echo "Detecting WSL distributions..."

for mount_point in /mnt/c /mnt/d; do
    if [ -d "$mount_point" ]; then
        echo "Scanning $mount_point..."
        detect_wsl_on_partition "$mount_point"
    fi
done

if [ -d "/media/mint/Windows" ]; then
    echo "Scanning /media/mint/Windows..."
    detect_wsl_on_partition "/media/mint/Windows"
fi

for mount_point in /media/*/Windows /mnt/*/Windows /media/*/C /mnt/*/C /media/*/D /mnt/*/D; do
    if [ -d "$mount_point" ] && [ "$mount_point" != "/media/mint/Windows" ]; then
        echo "Scanning $mount_point..."
        detect_wsl_on_partition "$mount_point"
    fi
done

if [ ! -s "$WSL_REPORT" ]; then
    echo "No WSL distributions found." >"$WSL_REPORT"
    echo "No WSL distributions detected."
else
    count=$(grep -c "WSL.*rootfs:" "$WSL_REPORT" 2>/dev/null || echo "0")
    echo "Found $count WSL distribution(s). Report written to $WSL_REPORT"
    echo "WSL distro shortnames:"
    print_shortnames
fi
