#!/bin/bash
# Persist home: USB — flush overlay to home.sfs; HDD — btrfs sync.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
. "$SCRIPT_DIR/lsl-common.sh"

lsl_load_config

if lsl_is_usb_mode; then
    echo "USB mode: flushing merged /home to /cdrom/home.sfs…"
    exec "$SCRIPT_DIR/lsl-flush-home.sh"
fi

echo "HDD mode: syncing btrfs…"
btrfs filesystem sync /home 2>/dev/null || true
if mountpoint -q /mnt/lsl-cache 2>/dev/null; then
    btrfs filesystem sync /mnt/lsl-cache 2>/dev/null || true
fi
if [ -x "$SCRIPT_DIR/persist-wifi.sh" ]; then
    "$SCRIPT_DIR/persist-wifi.sh" || true
fi
sync
echo "home/cache btrfs sync complete."
