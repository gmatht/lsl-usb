#!/bin/bash
set -euo pipefail

SRC_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
CDROM_ROOT="/cdrom"
CDROM_BIN="${CDROM_ROOT}/bin"

if [ "${EUID:-$(id -u)}" -ne 0 ]; then
    exec sudo "$0" "$@"
fi

if [ ! -d "$CDROM_ROOT" ]; then
    echo "Error: ${CDROM_ROOT} is missing."
    exit 1
fi

mount -o remount,rw "$CDROM_ROOT" || true
mkdir -p "$CDROM_BIN"

# Sync top-level boot scripts used directly from /cdrom.
for f in "$SRC_ROOT"/onboot.sh "$SRC_ROOT"/*.sh; do
    [ -f "$f" ] || continue
    install -m 0755 "$f" "${CDROM_ROOT}/$(basename "$f")"
done

# Sync all scripts in bin to /cdrom/bin.
for f in "$SRC_ROOT"/bin/*; do
    [ -f "$f" ] || continue
    install -m 0755 "$f" "${CDROM_BIN}/$(basename "$f")"
done

sync
mount -o remount,ro "$CDROM_ROOT" || true
echo "Updated /cdrom scripts from ${SRC_ROOT}."
